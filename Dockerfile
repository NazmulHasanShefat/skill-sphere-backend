# ১. নোড ভার্সন সিলেক্ট করা
FROM node:18

# ২. অ্যাপ ডিরেক্টরি তৈরি করা
WORKDIR /usr/src/app

# ৩. প্যাকেজ ফাইলগুলো কপি করা
COPY package*.json ./

# ৪. ডিপেন্ডেন্সি ইন্সটল করা
RUN npm install

# ৫. অ্যাপের সব কোড কপি করা
COPY . .

# ৬. আপনার অ্যাপ যে পোর্টে চলে সেটি এক্সপোজ করা
EXPOSE 8080

# ৭. অ্যাপ রান করার কমান্ড
CMD ["npm", "start"]